# ── Build output ────────────────────────────────────────────────
# /bin/  = `make binary` output (./bin/kloo)
# /dist/ = goreleaser output (cross-OS binaries, archives, checksums)
/bin/
/dist/

# ── Go compiled artifacts ───────────────────────────────────────
# Go builds straight to binaries (no separate build dir), so ignore loose
# compiled output, platform libraries, test binaries, and profiling output.
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
coverage.out
*.prof

# ── Go tooling / workspace ──────────────────────────────────────
# go.work[.sum] is a *local* multi-module override — machine-specific, not committed.
go.work
go.work.sum
# vendor/ stays tracked IF you vendor deps; kloo uses the module cache, so ignore it.
/vendor/

# ── Agent / tooling scratch ─────────────────────────────────────
# .aider*    = aider chat history / tag caches
# .johnnyone/ = J1 worker inbox + scratch written into the repo during runs
.aider*
.johnnyone/

# ── Local env / secrets ─────────────────────────────────────────
.env
.env.*
!.env.example

# ── Editor / OS noise ───────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db
benchmark/artifacts/*
benchmark/fixture/*
benchmark/reference/*
internal/llm/testdata/*
internal/tui/testdata/*
